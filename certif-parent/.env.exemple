# certif-parent/.env.exemple
# Variables d'environnement pour le développement local CertifApp
# Copier ce fichier en .env et remplir les valeurs sensibles
# Ne JAMAIS committer le fichier .env

# ─── Base de données ──────────────────────────────────────────────────────────
POSTGRES_PASSWORD=certifapp_dev_local

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Minimum 64 caractères (512 bits) en production
APP_JWT_SECRET=CHANGEME_minimum_64_caracteres_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
APP_JWT_EXPIRATION_MS=3600000         # 1 heure
APP_JWT_REFRESH_EXPIRATION_MS=604800000  # 7 jours

# ─── Spring profile ────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=local

# ─── Anthropic Claude (profil prod uniquement) ────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Stripe (paiements) ────────────────────────────────────────────────────────
# Mode test : https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
